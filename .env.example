# ─── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (replace with your Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/codesphere?retryWrites=true&w=majority

# JWT — use a long random secret in production
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional
GITHUB_TOKEN=your_github_personal_access_token
GEMINI_API_KEY=your_gemini_api_key
